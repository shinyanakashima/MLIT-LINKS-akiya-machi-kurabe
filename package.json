{
  "name": "mlit-links-akiya-machi-kurabe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "町ごとの空き家バンク健全性を俯瞰・比較する自治体向けダッシュボード（P5正規化データを集計・描画）",
  "license": "CC-BY-4.0",
  "scripts": {
    "fetch": "node scripts/fetch-data.mjs",
    "fixture": "node scripts/gen-fixture.mjs",
    "aggregate": "tsx scripts/aggregate.ts",
    "data": "npm run fetch && npm run aggregate",
    "prebuild": "npm run data",
    "dev": "npm run data && vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "test": "tsx --test scripts/__tests__/*.test.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
